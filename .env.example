# ─── File Upload ───────────────────────────────────────────────
# Maximum allowed upload size in megabytes (default: 200)
MAX_FILE_SIZE_MB=200

# Exposed to the browser for UI display (must match MAX_FILE_SIZE_MB)
NEXT_PUBLIC_MAX_FILE_SIZE_MB=200

# ─── File Cleanup ───────────────────────────────────────────────
# How long (in minutes) to keep temp files before automatic deletion (default: 30)
TEMP_FILE_TTL_MINUTES=30

# ─── Rate Limiting ──────────────────────────────────────────────
# Time window for rate limiting in milliseconds (default: 60000 = 1 minute)
RATE_LIMIT_WINDOW_MS=60000

# Maximum conversion requests per IP per window (default: 10)
RATE_LIMIT_MAX_REQUESTS=10

# ─── FFmpeg (Optional) ─────────────────────────────────────────
# If FFmpeg is not in your PATH, set the binary path here
# FFMPEG_PATH=/usr/bin/ffmpeg
# FFPROBE_PATH=/usr/bin/ffprobe

# ═══════════════════════════════════════════════════════════════
# AI Vocal Remover — dormant by default (set to true to enable)
# ═══════════════════════════════════════════════════════════════

# Master switch — set to true to expose the page and API routes
ENABLE_VOCAL_REMOVER=false

# ─── Redis (required for Vocal Remover) ────────────────────────
# BullMQ queue + job metadata store. Local default shown.
REDIS_URL=redis://localhost:6379

# ─── Demucs (required for Vocal Remover) ───────────────────────
# Path to the demucs binary. If demucs is in PATH, leave as default.
# Install: pip install demucs
# DEMUCS_PATH=demucs
# DEMUCS_MODEL=htdemucs

# ─── Vocal Remover — file limits ───────────────────────────────
# Maximum upload size in MB for the vocal remover (default: 100)
VR_MAX_FILE_SIZE_MB=100

# ─── Vocal Remover — job settings ──────────────────────────────
# How long (hours) to keep output stems before auto-deletion (default: 1)
VR_JOB_TTL_HOURS=1

# Timeout per job in milliseconds (default: 600000 = 10 minutes)
VR_JOB_TIMEOUT_MS=600000

# Number of BullMQ retry attempts per job (default: 2)
VR_JOB_ATTEMPTS=2

# ─── Vocal Remover — worker concurrency ────────────────────────
# How many jobs the worker processes simultaneously (default: 2)
# Lower this on memory-constrained servers (demucs uses ~2–4 GB RAM per job).
VR_MAX_CONCURRENT_JOBS=2

# Maximum concurrent uploads accepted by the upload API route (default: 3)
VR_MAX_CONCURRENT_UPLOADS=3
